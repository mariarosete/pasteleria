<Window x:Class="Acceso_A_Datos_MariaRS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Acceso_A_Datos_MariaRS"
        mc:Ignorable="d"
        Title="Pastelería Creativa"
        Height="650" Width="1000"
        Icon="/imagenes/postre.png"
        Background="#F2EBC4">

    <Window.Resources>

        <!-- Estilo se aplica a toda la aplicación en los botones.-->
        <!-- ESTILO VENTANA-->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="#D97F77"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#A53F2B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2C6B6"/>
                    <Setter Property="Foreground" Value="#A53F2B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- MULTIDISPARADOR -->
        <Style TargetType="TextBlock" x:Key="MultiTriggerTextBlockStyle">
            <Setter Property="Foreground" Value="#59252E"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsEnabled" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="17"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Barra de Scroll -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <!--Fondo de la barra de desplazamiento -->
                            <Rectangle Fill="Transparent" Width="14"/>

                            <!-- Botón de desplazamiento -->
                            <Thumb x:Name="Thumb"
                               Width="12"
                               Background="#D97F77"  
                               BorderBrush="#F2C6B6"
                               BorderThickness="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menú principal  -->
        <Menu Grid.Row="0" Background="#D97F77" Height="40" Padding="10, 0" VerticalAlignment="Top">
            
            <!-- Opciones  -->
            <MenuItem Header="Opciones" FontSize="15" FontWeight="Bold" Foreground="White" Padding="20, 10">
                <MenuItem.Icon>
                    <Image Source="/imagenes/opciones_icon.png" Width="25" />
                </MenuItem.Icon>

                <MenuItem Header="Insertar" Click="btnInsertar_Click" FontSize="13" Padding="20, 10" Background="#F2C6B6">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/agregar.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Modificar" Click="btnModificar_Click" FontSize="13" Padding="20, 10" Background="#F2C6B6">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/editar.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Borrar" Click="botnBorrar_Click" FontSize="13" Padding="20, 10" Background="#F2C6B6">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/borrar.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Salir" Click="botnSalir_Click" FontSize="13" Padding="20, 10" Background="#F2C6B6">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/exit.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!-- Desplazar  -->
            <MenuItem Header="Desplazar" FontSize="15" FontWeight="Bold" Foreground="White" Padding="20, 10">
                <MenuItem.Icon>
                    <Image Source="/imagenes/desplazar_icon.png" Width="25"/>
                </MenuItem.Icon>

                <MenuItem Header="Anterior" Click="btnAnterior_Click" FontSize="13" Padding="20, 10" Background="#F2C6B6">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/atras.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Siguiente" Click="btnSiguiente_Click" FontSize="13" Padding="20, 10" Background="#F2C6B6">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/siguiente.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" CornerRadius="15" BorderBrush="#59252E" BorderThickness="2" Padding="5" Margin="20">

            <!-- DataGrid para mostrar Recetas  -->
            <DataGrid Name="dgRecetas" ItemsSource="{Binding Path=recetas}" AutoGenerateColumns="False" 
                      RowDetailsVisibilityMode="VisibleWhenSelected" IsReadOnly="True"
                      Background="#F2C6B6" Foreground="#59252E" BorderBrush="#D97F77" 
                      RowBackground="#F2EBC4" AlternatingRowBackground="#F2C36B"
                      HorizontalAlignment="Center" Width="900" 
                      ColumnHeaderHeight="35" RowHeight="40"
                      SelectionUnit="FullRow"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="Foreground" Value="#A53F2B"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#D97F77"/>
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Chef" Binding="{Binding Chef}" Width="*" >
                        <DataGridTextColumn.ElementStyle>
                            
                            <!-- "DISPARADOR DE PROPIEDAD"-->
                            <!-- "Al pasar el ratón cambia de color de texto y lo subraya"-->
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="Foreground" Value="#59252E"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>


                <!-- Mostrar detalles DataGrid -->
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <DockPanel Background="#F2C6B6">
                            <Image DockPanel.Dock="Left" Height="80" Margin="10" Source="{Binding ImagenBitmap}" />
                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- APLICAR MULTIDISPARADOR -->
                                <TextBlock Text="Id: " FontWeight="Bold" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                                <TextBlock Text="{Binding Id}" Grid.Column="1" TextAlignment="Left" Style="{StaticResource MultiTriggerTextBlockStyle}"/>

                                <TextBlock Text="Nombre: " FontWeight="Bold" Grid.Row="1" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                                <TextBlock Text="{Binding Nombre}" Grid.Column="1" Grid.Row="1" TextAlignment="Left" Style="{StaticResource MultiTriggerTextBlockStyle}"/>

                                <TextBlock Text="Chef: " FontWeight="Bold" Grid.Row="2" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                                <TextBlock Text="{Binding Chef}" Grid.Column="1" Grid.Row="2" TextAlignment="Left" Style="{StaticResource MultiTriggerTextBlockStyle}"/>

                                <TextBlock Text="Tipo: " FontWeight="Bold" Grid.Row="3" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                                <TextBlock Text="{Binding Tipo}" Grid.Column="1" Grid.Row="3" TextAlignment="Left" Style="{StaticResource MultiTriggerTextBlockStyle}"/>

                                <TextBlock Text="Tiempo: " FontWeight="Bold" Grid.Row="4" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                                <TextBlock Text="{Binding TiempoPreparacion}" Grid.Column="1" Grid.Row="4" TextAlignment="Left" Style="{StaticResource MultiTriggerTextBlockStyle}"/>

                                <TextBlock Text="Dificultad: " FontWeight="Bold" Grid.Row="5" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                                <TextBlock Text="{Binding Dificultad}" Grid.Column="1" Grid.Row="5" TextAlignment="Left" Style="{StaticResource MultiTriggerTextBlockStyle}"/>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>

                
            </DataGrid>
        </Border>

        <!-- Botones-->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <StackPanel.Resources>
                
                <!-- Estilo SOLO para btnAnterior y btnSiguiente -->
                <Style TargetType="Button" x:Key="HoverButtonStyle">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F2C6B6"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Estilo para los demás botones -->
                <Style TargetType="Button" x:Key="NoHoverButtonStyle">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </StackPanel.Resources>

            <!-- Botones con hover -->
            <Button Name="btnAnterior" Width="50" Click="btnAnterior_Click" Margin="5" ToolTip="Anterior" Style="{StaticResource HoverButtonStyle}">
                <Image Source="/imagenes/atras.png" Height="20"/>
            </Button>
            <Button Name="btnSiguiente" Width="50" Click="btnSiguiente_Click" Margin="5" ToolTip="Siguiente" Style="{StaticResource HoverButtonStyle}">
                <Image Source="/imagenes/siguiente.png" Height="20"/>
            </Button>

            <!-- Botones sin hover -->
            <Button Name="btnInsertar" Width="60" Click="btnInsertar_Click" Margin="5" Style="{StaticResource NoHoverButtonStyle}" ToolTip="Insertar" RenderTransformOrigin="0.5,0.5">
                
                <!-- ANIMACIÓN para botón insertar -->
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.3" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.3" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <Image Source="/imagenes/agregar.png" Height="40"/>
            </Button>
            
            <Button Name="btnModificar" Width="60" Click="btnModificar_Click" Margin="5" Style="{StaticResource NoHoverButtonStyle}" ToolTip="Modificar" RenderTransformOrigin="0.5,0.5">

                <!-- ANIMACIÓN para botón modificar -->
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.3" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.3" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <Image Source="/imagenes/editar.png" Height="40"/>
            </Button>
            
            <Button Name="btnBorrar" Width="60" Click="botnBorrar_Click" Margin="5" Style="{StaticResource NoHoverButtonStyle}" ToolTip="Borrar" RenderTransformOrigin="0.5,0.5">

                <!-- ANIMACIÓN para botón eliminar -->
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.3" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.3" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <Image Source="/imagenes/borrar.png" Height="40"/>
            </Button>
        </StackPanel>

        <!-- Menu Contextual-->
        <Grid.ContextMenu>
            <ContextMenu Name="contextMenu">
                
                <!-- Opción Insertar -->
                <MenuItem Header="Insertar" Click="btnInsertar_Click" Background="#F2EBC4" FontSize="13" Padding="20, 10">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/agregar.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <!-- Opción Modificar -->
                <MenuItem Header="Modificar" Click="btnModificar_Click" Background="#F2EBC4" FontSize="13" Padding="20, 10">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/editar.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <!-- Opción Borrar -->
                <MenuItem Header="Borrar" Click="botnBorrar_Click" Background="#F2EBC4" FontSize="13" Padding="20, 10">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/borrar.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <!-- Separador -->
                <Separator/>

                <!-- Opción Anterior -->
                <MenuItem Header="Anterior" Click="btnAnterior_Click" Background="#F2EBC4" FontSize="13" Padding="20, 10">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/atras.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>

                <!-- Opción Siguiente -->
                <MenuItem Header="Siguiente" Click="btnSiguiente_Click" Background="#F2EBC4" FontSize="13" Padding="20, 10">
                    <MenuItem.Icon>
                        <Image Source="/imagenes/siguiente.png" Width="25"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Grid.ContextMenu>

    </Grid>

</Window>
