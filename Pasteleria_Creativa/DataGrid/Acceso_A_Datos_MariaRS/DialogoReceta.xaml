<Window x:Class="Acceso_A_Datos_MariaRS.DialogoReceta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Acceso_A_Datos_MariaRS"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Insertar Nueva Receta"
        
        Height="450" Width="800"
        Background="#F2EBC4">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            
            <!-- Estilo de los TextBlocks -->
            <Style TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#A53F2B"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Estilo de los TextBoxes -->
            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="#59252E"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="BorderBrush" Value="#D97F77"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Margin" Value="10,5"/>
            </Style>

            <!-- Estilo del ComboBox -->
            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="#59252E"/>
                <Setter Property="BorderBrush" Value="#D97F77"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Margin" Value="10,5"/>
            </Style>

            <!-- Estilo de los botones -->
            <Style TargetType="Button" x:Key="HoverButtonStyle">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#D97F77"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="#59252E"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="2" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F2C6B6"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <!-- Campos del formulario -->
        <TextBlock Text="Nombre:" Grid.Row="0"/>
        <TextBox Text="{Binding Nombre}" Grid.Row="0" Grid.Column="1" Width="250"/>

        <TextBlock Text="Chef:" Grid.Row="1"/>
        <TextBox Text="{Binding Chef}" Grid.Row="1" Grid.Column="1" Width="250"/>

        <TextBlock Text="Tipo:" Grid.Row="2"/>
        <TextBox Text="{Binding Tipo}" Grid.Row="2" Grid.Column="1" Width="250"/>

        <TextBlock Text="Tiempo:" Grid.Row="3"/>
        <TextBox Text="{Binding TiempoPreparacion}" Grid.Row="3" Grid.Column="1" Width="250"/>

        <TextBlock Text="Dificultad:" Grid.Row="4"/>
        <ComboBox SelectedValue="{Binding Dificultad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Width="250">
            <ComboBox.ItemsSource>
                <x:Array Type="{x:Type sys:String}">
                    <sys:String>Baja</sys:String>
                    <sys:String>Media</sys:String>
                    <sys:String>Alta</sys:String>
                </x:Array>
            </ComboBox.ItemsSource>
        </ComboBox>

        <TextBlock Text="Imagen:" Grid.Row="5"/>
        <TextBox Text="{Binding Imagen}" Grid.Row="5" Grid.Column="1" Width="250"/>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="6" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Button Name="btnGuardar" Content="Guardar" Width="100" Click="btnGuardar_Click" Margin="10" Style="{StaticResource HoverButtonStyle}"/>
            <Button Name="btnCancelar" Content="Cancelar" Width="100" Click="btnCancelar_Click" Margin="10" Style="{StaticResource HoverButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
